{
  "parser": "@typescript-eslint/parser",
  "plugins": [
    "@typescript-eslint"
  ],
  "extends": [
    "plugin:@typescript-eslint/recommended",
    "next"
  ],
  "ignorePatterns": [
    "wix-site-code",
    "beer-data.js",
    "next-env.d.ts"
  ],
  "rules": {
    "semi": [
      "error",
      "never"
    ],
    "@typescript-eslint/no-require-imports": "off"
  },
  "overrides": [
    {
      "files": [
        "next.config.js"
      ],
      "rules": {
        "@typescript-eslint/ban-ts-comment": "off",
        "semi": "off"
      }
    }
  ]
}
